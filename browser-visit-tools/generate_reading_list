#!/usr/bin/env bash
# generate_reading_list — convenience wrapper around
# reading_list.py.
#
# Reads the visit DB and writes
# ~/Documents/browser-visit-logger/reading_list.md, a Markdown file
# listing every URL marked of_interest but not read, split into a
# "Skimmed" table and a "To skim" table.  Rerun any time to refresh.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TARGET="$SCRIPT_DIR/reading_list.py"

for arg in "$@"; do
  case "$arg" in
    -h|--help)
      cat <<'EOF'
generate_reading_list — wrapper around reading_list.py

Reads the visit DB and writes a Markdown reading list of URLs tagged
of_interest but not yet read, split into Skimmed and To skim tables.
All arguments are forwarded verbatim to the Python script.

The remainder of this help is from the Python script:

EOF
      exec python3 "$TARGET" --help
      ;;
  esac
done

exec python3 "$TARGET" "$@"
